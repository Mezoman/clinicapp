{
  "name": "dcms",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "نظام إدارة عيادة الدكتور محمد أسامة الرفاعي",
  "scripts": {
    "dev": "vite",
    "generate:types": "npx -y supabase gen types typescript --project-id snqttayzyyxpzicudurb > src/database.types.ts",
    "generate:schemas": "npx -y ts-to-zod src/database.types.ts src/infrastructure/contracts/generated.schemas.ts",
    "contracts:sync": "npm run generate:types && npm run generate:schemas",
    "contracts:verify": "node scripts/verify-contracts.js",
    "contracts:drift-check": "npm run contracts:sync && git diff --exit-code src/database.types.ts src/infrastructure/contracts/generated.schemas.ts",
    "prebuild": "npm run contracts:verify",
    "build": "tsc -b && vite build",
    "build:local": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:report": "eslint src/ --format json -o eslint-report.json",
    "audit:strict": "speckit analyze . --deep --strict --block-on-fail"
  },
  "dependencies": {
    "@sentry/browser": "^10.40.0",
    "@sentry/react": "^10.40.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tanstack/react-query": "^5.90.21",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "sonner": "^1.7.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "lightningcss": "^1.32.0",
    "speckit": "^0.1.0",
    "tailwindcss": "^4.0.0",
    "ts-to-zod": "^5.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.1.0",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^4.0.18",
    "workbox-window": "^7.3.0"
  }
}
